.pnpm-debug.log*
*.log

# Environment (do not ignore .env.example)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# Testing & coverage
coverage/
